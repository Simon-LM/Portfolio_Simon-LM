{
	"name": "my-next-project",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"test:a11y": "pa11y-ci",
		"test:a11y:single": "pa11y http://localhost:3000"
	},
	"jest": {
		"testEnvironment": "jsdom",
		"setupFilesAfterEnv": [
			"<rootDir>/jest.setup.js"
		],
		"moduleNameMapper": {
			"\\.(css|less|scss|sass)$": "identity-obj-proxy",
			"^@/(.*)$": "<rootDir>/src/$1"
		},
		"transform": {
			"^.+\\.(js|jsx|ts|tsx)$": [
				"babel-jest",
				{
					"presets": [
						"next/babel"
					]
				}
			]
		}
	},

			"\\.(css|less|scss|sass)$": "identity-obj-proxy",
			"^@/(.*)$": "<rootDir>/src/$1"
		},
		"transform": {
			"^.+\\.(js|jsx|ts|tsx)$": [
				"babel-jest",
				{
					"presets": [
						"next/babel"
					]
				}

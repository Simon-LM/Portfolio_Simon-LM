{
	"name": "darkmode-plus-a11y",
	"version": "0.4.2",
	"description": "Dark mode plus 14 more accessible themes (high contrast, color-vision deficiency, anti-glare), generated from your light theme at Sass compile time — with WCAG contrast enforced mechanically, accessible fonts, and a scaffolded accessibility menu.",
	"keywords": [
		"accessibility",
		"a11y",
		"dark-mode",
		"themes",
		"high-contrast",
		"color-blind",
		"wcag",
		"scss",
		"sass",
		"design-tokens",
		"dyslexia",
		"react"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Simon-LM/Portfolio_Simon-LM.git",
		"directory": "packages/darkmode-plus-a11y"
	},
	"homepage": "https://github.com/Simon-LM/Portfolio_Simon-LM/tree/main/packages/darkmode-plus-a11y#readme",
	"bugs": {
		"url": "https://github.com/Simon-LM/Portfolio_Simon-LM/issues"
	},
	"license": "MIT AND OFL-1.1",
	"exports": {
		"./scss/*": "./scss/*",
		"./react": {
			"types": "./dist/react/index.d.ts",
			"default": "./dist/react/index.js"
		},
		"./react/*": {
			"types": "./dist/react/*.d.ts",
			"default": "./dist/react/*.js"
		},
		"./testing/*": {
			"types": "./dist/testing/*.d.ts",
			"default": "./dist/testing/*.js"
		}
	},
	"bin": {
		"darkmode-plus-a11y": "bin/cli.mjs"
	},
	"files": [
		"LICENSE",
		"AGENTS.md",
		"scss",
		"react",
		"fonts",
		"templates",
		"bin",
		"testing",
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"prepack": "pnpm build"
	},
	"peerDependencies": {
		"react": ">=18"
	},
	"dependencies": {
		"culori": "^4.0.2",
		"postcss": "^8.5.16",
		"sass": "^1.101.0"
	},
	"devDependencies": {
		"@types/node": "^22.13.1",
		"@types/react": "^19.0.8",
		"typescript": "^5.7.3"
	},
	"author": "Simon LM (LostInTab)"
}
